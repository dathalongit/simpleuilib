{
  "name": "react-headless-quiz-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter react-headless-quiz build",
    "dev": "pnpm --filter showcase-demo dev",
    "dev:showcase": "pnpm --filter showcase-demo dev",
    "dev:default": "pnpm --filter default-demo dev",
    "dev:tailwind": "pnpm --filter tailwind-demo dev",
    "dev:bootstrap": "pnpm --filter bootstrap-demo dev",
    "dev:mui": "pnpm --filter mui-demo dev",
    "dev:compound": "pnpm --filter compound-slot-demo dev",
    "dev:compound-only": "pnpm --filter compound-demo dev",
    "dev:headless": "pnpm --filter tailwind-headless-demo dev",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.21.0"
  },
  "engines": {
    "node": ">=18"
  }
}
